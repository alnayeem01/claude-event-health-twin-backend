# PostgreSQL — Render / cloud (takes precedence over PG* vars)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME

# PostgreSQL — local (used when DATABASE_URL is unset)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=health_twin

# API server (use 3001 when Next.js uses 3000)
PORT=3001

# AWS Bedrock (Converse API — Claude, Nova, etc.)
# Use the same region where you enabled model access in the Bedrock console.
# Local dev: IAM user with bedrock:InvokeModel (omit on EC2/Lambda with an IAM role).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# CORS: comma-separated Next.js origins (or leave unset for permissive dev)
FRONTEND_ORIGIN=http://localhost:3000

# Smoke tests (optional)
# SMOKE_PORT=3099
