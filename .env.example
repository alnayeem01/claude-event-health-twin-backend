# PostgreSQL — Render / cloud (takes precedence over PG* vars)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME

# PostgreSQL — local (used when DATABASE_URL is unset)
PGHOST=localhost
PGPORT=5432
PGUSER=utsavgohel
PGPASSWORD=
PGDATABASE=bench_pgvector

# Server
PORT=3000

# LLM: gemini (default) or bedrock (AWS; enable model access in Bedrock console)
# LLM_PROVIDER=gemini

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# AWS Bedrock (when LLM_PROVIDER=bedrock) — IAM creds or instance role; Claude must be enabled in Bedrock
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

LLM_PROVIDER=bedrock
AWS_REGION=eu-west-2
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# CORS: comma-separated origins, or leave unset for permissive (dev)
# FRONTEND_ORIGIN=http://localhost:5173
